          },
          "expr": "sum(rate(therapy_llm_capture_records_total{status=\"journaled\"}[30m])) / clamp_min(sum(rate(therapy_llm_capture_records_total{status=~\"journaled|failed\"}[30m])), 0.000001)",
          "refId": "A"
        }
      ],
      "title": "SLI: capture journaled-vs-failed ratio",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Definition: journaled LLM attempts without explicit incomplete evidence divided by all journaled attempts; terminal completions and exact provider errors are complete. Target: 100%, with zero incomplete accepted evaluations.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
