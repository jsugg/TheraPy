        "y": 65
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "1 - (sum(rate(therapy_llm_capture_records_total{status=\"incomplete\"}[30m])) / clamp_min(sum(rate(therapy_llm_capture_records_total{status=\"journaled\"}[30m])), 0.000001))",
          "refId": "A"
        }
      ],
      "title": "SLI: evaluation evidence completeness ratio",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Definition: current time minus the oldest unexported restricted-record timestamp. Target: < 3600 seconds; the journal remains authoritative.",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
