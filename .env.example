# LLM provider (SPEC §5: cloud Claude default, swappable)
THERAPY_LLM=anthropic            # anthropic | openrouter | ollama
# THERAPY_LLM_MODEL=             # optional model override for the chosen provider
ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=            # required when THERAPY_LLM=openrouter
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
#   ^ required when THERAPY_LLM=ollama and the server runs in Docker
#     (Ollama itself runs on the host: `ollama serve`, `ollama pull gemma3:4b`)

# Speech
# THERAPY_WHISPER_MODEL=small    # faster-whisper model (multilingual)
# THERAPY_VOICE_EN=af_heart      # Kokoro voice overrides, per language
# THERAPY_VOICE_ES=ef_dora
# THERAPY_VOICE_PT=pf_dora

# Safety
# THERAPY_CRISIS_RESOURCES=      # locale-specific hotlines/contacts (SPEC §4)

# WebRTC TURN relay (compose `turn` service; needed for the phone over
# Tailscale — see compose.yaml). Defaults work out of the box on a tailnet.
# THERAPY_TURN_USER=therapy
# THERAPY_TURN_PASSWORD=therapy-local
# THERAPY_TURN_PORT=3478
