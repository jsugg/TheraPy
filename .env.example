# LLM provider (SPEC §5: cloud Claude default, swappable)
THERAPY_LLM=anthropic            # anthropic | openrouter | ollama
# THERAPY_LLM_MODEL=             # optional model override for the chosen provider
ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=            # required when THERAPY_LLM=openrouter
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
#   ^ required when THERAPY_LLM=ollama and the server runs in Docker
#     (Ollama itself runs on the host: `ollama serve`, `ollama pull pedrolucas/smollm3:3b-q4_k_m`)

# Speech
# THERAPY_WHISPER_MODEL=small    # faster-whisper model (multilingual).
#   Measured 2026-07-10 (Intel Mac, CPU int8): large-v3-turbo pushed warm
#   TTFA from 9-13s to 34-124s — not viable without a GPU. Real STT
#   quality gains are gated on the VPS/GPU migration.
# THERAPY_VOICE_EN=af_heart      # Kokoro voice overrides, per language
# THERAPY_VOICE_ES=ef_dora
# THERAPY_VOICE_PT=pf_dora

# Voice-activity detection (tunable without a rebuild; defaults favor real
# phone speech over opus — raise thresholds if ambient noise triggers turns)
# THERAPY_VAD_CONFIDENCE=0.6
# THERAPY_VAD_MIN_VOLUME=0.3
# THERAPY_VAD_STOP_SECS=1.2      # silence that ends an utterance

# Sessions
# THERAPY_RESUME_WINDOW_SECS=900 # reconnect within this window resumes the
#                                # interrupted session (0 disables resume)

# Safety
# Environment-only: JSON array, max 20; each object must contain exactly
# non-empty string fields `label` (<=100 chars) and `value` (<=300 chars).
# Restart after editing. Malformed config is surfaced by
# `/api/crisis-resources`; the crisis response itself retains a safe fallback.
# THERAPY_CRISIS_CONTACTS=[{"label":"CVV Brasil","value":"188"},{"label":"Emergency","value":"190"}]
# THERAPY_CRISIS_RESOURCES=      # legacy plain-string fallback (<=2000 chars)

# Fully local OCR for imported images/scanned PDFs. Install matching Tesseract
# packs outside Docker; the shipped image includes all three.
# THERAPY_OCR_LANGUAGES=eng+spa+por

# Web Push VAPID identity; the private key is generated locally under data/.
# THERAPY_VAPID_SUBJECT=mailto:owner@example.com

# WebRTC TURN relay (compose `turn` service; needed for the phone over
# Tailscale — see compose.yaml). Defaults work out of the box on a tailnet.
# THERAPY_TURN_USER=therapy
# THERAPY_TURN_PASSWORD=therapy-local
# THERAPY_TURN_PORT=3478

# --- Observability (two-plane; synthetic-only scope, see .local/working-notes/evidence/) ---
# All defaults are safe: capture journals locally, nothing leaves the host.
# Promotion triggers (genuine data, public exposure, remote export) require
# an explicit new threat-model decision before flipping anything here.
# THERAPY_CAPTURE_MODE=runtime          # disabled | runtime | evaluation
# THERAPY_INTERACTION_JOURNAL=          # default: $THERAPY_DATA_DIR/interaction-journal.sqlite3
# THERAPY_INTERACTION_BACKEND=journal   # journal | phoenix (O0 ADR winner)
# THERAPY_INTERACTION_REMOTE_EXPORT=0   # explicit owner gate for any remote egress
# THERAPY_INTERACTION_RETENTION_DAYS=30 # unacknowledged records never expire
# THERAPY_INTERACTION_QUEUE_SIZE=256
# THERAPY_INTERACTION_GROUP_COMMIT_MS=50
# THERAPY_OTEL_ENABLED=0                # broad traces/metrics export (O2)
# THERAPY_OTLP_BROAD_ENDPOINT=http://localhost:4318
# THERAPY_OTLP_RESTRICTED_ENDPOINT=     # e.g. http://phoenix:6006 with the
#                                       # `llm-observability` compose profile
# THERAPY_OTEL_EXPORT_TIMEOUT_SECS=3
# THERAPY_ENVIRONMENT=development       # development | test | dogfood | vps-test
# THERAPY_LOG_LEVEL=INFO
# THERAPY_CLIENT_TELEMETRY=0            # browser telemetry endpoint (O4)
